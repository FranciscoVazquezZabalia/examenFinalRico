<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.examenRecup.controller.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <Label text="Gestión de Usuarios" style="-fx-font-size: 26px; -fx-font-weight: bold;"/>
    <Label text="Introduce tu email y contraseña" style="-fx-font-size: 13px; -fx-text-fill: gray;"/>

    <TextField fx:id="emailField" promptText="Email" maxWidth="260" prefHeight="35"/>
    <PasswordField fx:id="passwordField" promptText="Contraseña" maxWidth="260" prefHeight="35"/>

    <Label fx:id="errorLabel" text="" style="-fx-text-fill: red; -fx-font-size: 12px;" visible="false" managed="false"/>

    <Button fx:id="loginButton" text="Entrar" prefWidth="260" prefHeight="35"
            style="-fx-background-color: #7dc2fa; -fx-text-fill: white; -fx-font-weight: bold;"/>
</VBox>
