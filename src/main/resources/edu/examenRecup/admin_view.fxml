<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.examenRecup.controller.AdminViewController">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS">
        <content>
            <VBox spacing="20.0">
                <padding>
                    <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
                </padding>
                <Label text="Usuarios" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <FlowPane fx:id="cardsContainer" hgap="15.0" vgap="15.0"/>
            </VBox>
        </content>
    </ScrollPane>

    <VBox spacing="10.0" minWidth="220.0">
        <padding>
            <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
        </padding>
        <Label text="Panel Admin" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
        <Label text="ID:"/>
        <TextField fx:id="idField" editable="false"/>
        <Label text="Nombre:"/>
        <TextField fx:id="nombreField"/>
        <Label text="Nickname:"/>
        <TextField fx:id="nicknameField"/>
        <Label text="Email:"/>
        <TextField fx:id="emailField"/>
        <Label text="Edad:"/>
        <TextField fx:id="edadField"/>
        <Label text="Password:"/>
        <TextField fx:id="passwordField"/>
        <Label text="Rol:"/>
        <ComboBox fx:id="roleComboBox" maxWidth="200.0"/>
        <Label fx:id="errorLabel" text="" style="-fx-text-fill: red;" visible="false" managed="false"/>
        <Button fx:id="addButton" text="Add" maxWidth="200.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
        <Button fx:id="updateButton" text="Update" maxWidth="200.0" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        <Button fx:id="deleteButton" text="Delete" maxWidth="200.0" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
        <Button fx:id="clearButton" text="Clear" maxWidth="200.0"/>
    </VBox>
</HBox>
